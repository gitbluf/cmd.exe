{
  "name": "cmd.exe",
  "version": "0.1.0-alpha.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "pi": {
    "extensions": [
      "./src"
    ]
  },
  "keywords": [
    "pi-package",
    "pi-extension"
  ],
  "scripts": {
    "build": "bun x tsc",
    "watch": "bun x tsc --watch",
    "clean": "rm -rf dist",
    "lint": "bun x biome lint .",
    "format": "bun x biome format .",
    "check": "bun x biome check .",
    "fix": "bun x biome check --write .",
    "fix:unsafe": "bun x biome check --write --unsafe ."
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "0.0.39",
    "@mariozechner/pi-ai": "0.55.1",
    "@mariozechner/pi-coding-agent": "0.55.0",
    "@mariozechner/pi-tui": "0.55.1",
    "@sinclair/typebox": "0.34.48"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "typescript": "5.0.4"
  }
}
